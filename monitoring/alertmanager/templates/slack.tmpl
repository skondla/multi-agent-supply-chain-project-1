{{ define "slack.supply_chain.title" -}}
  [{{ .Status | toUpper }}{{ if eq .Status "firing" }}:{{ .Alerts.Firing | len }}{{ end }}]
  {{ .CommonLabels.alertname }} for {{ .CommonLabels.job }}
  {{- if gt (len .CommonLabels) (len .GroupLabels) -}}
    {{" "}}(
    {{- with .CommonLabels.Remove .GroupLabels.Names }}
      {{- range $index, $label := .SortedPairs -}}
        {{ if $index }}, {{ end }}
        {{- $label.Name }}="{{ $label.Value -}}"
      {{- end }}
    {{- end -}}
    )
  {{- end }}
{{- end }}

{{ define "slack.supply_chain.color" -}}
  {{ if eq .Status "firing" -}}
    {{ if eq .CommonLabels.severity "critical" }}danger{{ else }}warning{{ end }}
  {{- else -}}
    good
  {{- end }}
{{- end }}

{{ define "slack.supply_chain.icon_emoji" -}}
  {{ if eq .Status "firing" -}}
    {{ if eq .CommonLabels.severity "critical" }}:fire:{{ else }}:warning:{{ end }}
  {{- else -}}
    :white_check_mark:
  {{- end }}
{{- end }}
