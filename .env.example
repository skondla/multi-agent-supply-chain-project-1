# =============================================================================
# Supply Chain AI Platform - Environment Configuration
# Copy to .env and fill in your values
# =============================================================================

# Application
APP_ENV=development
APP_NAME=supply-chain-ai
APP_VERSION=1.0.0
APP_SECRET_KEY=change-me-to-a-random-secret-key-min-32-chars
DEBUG=false
LOG_LEVEL=INFO
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# API Server
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=false

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://supply_chain:password@localhost:5432/supply_chain
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP=supply-chain-consumers
KAFKA_TOPIC_ORDERS=supply-chain.orders
KAFKA_TOPIC_INVENTORY=supply-chain.inventory
KAFKA_TOPIC_ALERTS=supply-chain.alerts

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-your-api-key-here
CLAUDE_MODEL=claude-opus-4-6
CLAUDE_MAX_TOKENS=4096

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
S3_BUCKET=supply-chain-artifacts

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=supply-chain-ml
MLFLOW_S3_ENDPOINT_URL=

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Slack Notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_CHANNEL=#supply-chain-alerts
SLACK_BOT_TOKEN=xoxb-your-bot-token

# JWT Authentication
JWT_SECRET_KEY=change-me-to-a-random-jwt-secret-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
JWT_REFRESH_EXPIRE_DAYS=7

# Monitoring
PROMETHEUS_PORT=9090
JAEGER_HOST=localhost
JAEGER_PORT=6831
OTEL_SERVICE_NAME=supply-chain-api

# LLM Cost Tracking
LLM_DAILY_BUDGET_USD=100.0
LLM_ALERT_THRESHOLD_PERCENT=80

# Feature Flags
ENABLE_ML_FORECASTING=true
ENABLE_ANOMALY_DETECTION=true
ENABLE_AUTO_REORDER=true
ENABLE_SEMANTIC_CACHE=true
